pipeline {
    agent none

    stages {
        stage('Build and test') {
            agent {
                docker {
                    image 'node:22-alpine'
                    args '-v npm-cache:/home/node/.npm'
                }
            }
            steps {
                dir('frontend') {
                    sh '''
                        npm ci
                        npm run lint
                        npm test
                    '''
                }
            }
            post {
                always {
                    dir('frontend') {
                        junit 'reports/junit.xml'
                    }
                }
            }
        }
    }
}